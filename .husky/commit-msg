#!/bin/sh
# commit-msg hook — validates commit message format
# Ensures conventional commit format and checks for violation keywords.

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Check conventional commit format: type(scope): description
if ! echo "$COMMIT_MSG" | grep -qE '^(feat|fix|refactor|chore|docs|test|style|perf|ci|build|revert)(\(.+\))?: .{1,}'; then
  echo "⚠ Commit message does not follow Conventional Commits format."
  echo "  Expected: type(scope): description"
  echo "  Types: feat, fix, refactor, chore, docs, test, style, perf, ci, build, revert"
  echo ""
  echo "  Your message: $COMMIT_MSG"
  exit 1
fi
