#!/bin/sh
# pre-commit hook — fast checks only (lint + typecheck)
# Full test suite runs in CI, not in pre-commit (too slow: ~240s for 1045 tests).

echo "🔍 Checking file sizes..."
OVERSIZED_FILES=$(find src/ -name '*.ts' -not -path 'src/__tests__/*' -not -path 'src/templates/*' -exec sh -c 'lines=$(wc -l < "$1"); if [ "$lines" -gt 300 ]; then echo "⚠️  File too large ($lines lines > 300): $1"; fi' _ {} \;)
if [ -n "$OVERSIZED_FILES" ]; then
  echo "$OVERSIZED_FILES"
  echo "⚠️  Some files exceed 300 lines. Refactor before merging to main."
fi
echo "✅ File sizes check complete."

echo "🔍 Running lint..."
pnpm run lint
LINT_EXIT=$?

if [ $LINT_EXIT -ne 0 ]; then
  echo "❌ Lint failed. Fix errors before committing."
  exit 1
fi

echo "🔍 Running typecheck..."
pnpm run typecheck
TSC_EXIT=$?

if [ $TSC_EXIT -ne 0 ]; then
  echo "❌ Typecheck failed. Fix errors before committing."
  exit 1
fi

echo "🔍 Checking documentation sync..."
pnpm run sync:docs --quiet || true
SYNC_EXIT=$?

if [ $SYNC_EXIT -ne 0 ]; then
  echo "⚠️  Documentation sync has warnings. Run 'pnpm run sync:docs:fix' to auto-fix."
fi

echo "✅ Pre-commit checks passed."
