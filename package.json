{
  "name": "nexus-system",
  "version": "0.1.0",
  "description": "AI governance framework that grows with your project — scoring, pattern detection, health auditing",
  "type": "module",
  "bin": {
    "nexus": "./dist/nexus.js"
  },
  "main": "./dist/nexus.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/nexus.js"
  },
  "scripts": {
    "build": "tsup && rm -rf dist/templates && cp -r src/templates dist/templates",
    "dev": "tsx bin/nexus.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "pretest": "tsc --noEmit",
    "test:watch": "vitest",
    "bench": "vitest bench src/__tests__/benchmarks.bench.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "test:coverage": "vitest run --coverage",
    "validate-publish": "npm run build && npm pack --dry-run && echo 'Ready to publish'",
    "lint": "eslint 'src/**/*.ts' --max-warnings=0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "governance",
    "opencode",
    "engineering",
    "framework",
    "scoring",
    "pattern-detection",
    "health-audit"
  ],
  "author": "Edson Ramos <edson.ramos@nexus-system.com>",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ednosmab/nexus-system.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ink-tools/ink-mouse": "^2.1.0",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "ink": "^7.1.0",
    "inquirer": "^9.3.0",
    "ora": "^8.1.0",
    "react": "^19.2.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "ink-testing-library": "^4.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
