{
  "name": "nexus-governance",
  "version": "0.1.0",
  "description": "AI governance framework that grows with your project — scoring, pattern detection, health auditing",
  "type": "module",
  "bin": {
    "nexus": "./dist/nexus.js"
  },
  "main": "./dist/nexus.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/nexus.js"
  },
  "scripts": {
    "build": "tsup bin/nexus.ts --format esm --dts && cp -r src/templates dist/templates",
    "dev": "tsx bin/nexus.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench src/__tests__/benchmarks.bench.ts",
    "clean": "rm -rf dist node_modules *.tsbuildinfo",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "governance",
    "opencode",
    "engineering",
    "framework",
    "scoring",
    "pattern-detection",
    "health-audit"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/nexus-governance.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.3.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.10",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
}
